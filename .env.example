# Tarayıcıda kullanılabilen Supabase proje bilgileri
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Yalnızca sunucu/Vercel secret olarak tanımlayın. NEXT_PUBLIC_ kullanmayın.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# En az 32 rastgele bayttan oluşan Google Form webhook HMAC anahtarı
GOOGLE_FORM_WEBHOOK_SECRET=replace-with-a-long-random-secret

# Faz 1'de atomik restore tamamlanana kadar false bırakın.
ENABLE_DANGEROUS_RESTORE=false
