{
  "name": "antigravity-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "test:unit": "tsx --test tests/report-metrics.test.ts",
    "test:security": "tsx --test tests/security-regressions.test.ts tests/webhook-signature.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:local": "sh scripts/run-e2e-local.sh",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:lint": "supabase db lint --schema public --level warning",
    "db:test": "supabase test db",
    "quality": "npm run lint && npm run typecheck && npm test && npm audit --omit=dev --audit-level=high && npm run build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/papaparse": "^5.5.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.11",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "read-excel-file": "^9.3.3",
    "recharts": "^3.9.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15",
      "sharp": "0.35.3"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "supabase": "^2.109.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "ws": "^8.21.1"
  }
}
